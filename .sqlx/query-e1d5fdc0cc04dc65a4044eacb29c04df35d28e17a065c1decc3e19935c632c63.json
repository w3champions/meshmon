  "query": "SELECT m.source_agent_id,\n                  m.destination_ip,\n                  m.latency_avg_ms,\n                  m.latency_stddev_ms,\n                  m.loss_pct,\n                  m.id AS measurement_id,\n                  m.mtr_id\n             FROM measurements m\n             JOIN campaign_pairs cp ON cp.measurement_id = m.id\n            WHERE cp.campaign_id = $1\n              AND cp.kind = 'campaign'",
