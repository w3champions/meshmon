  "description": "Per-agent view. Row 1 = this agent probing out. Row 2 = other agents probing this agent. Parameterized by $source. Panel IDs frozen — see grafana/panels.json.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 10,
      "title": "Outgoing (this agent as source)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Outgoing RTT avg — $source → *",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "MeshmonVM" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 1 },
      "description": "Average RTT (ms) for each outgoing path from $source. One series per target+protocol.",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 0,
            "spanNulls": 60000,
            "showPoints": "never",
            "axisLabel": "RTT (ms)",
            "axisSoftMin": 0
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "MeshmonVM" },
          "expr": "meshmon_path_rtt_avg_micros{source=\"$source\"} / 1000",
          "legendFormat": "→ {{target}} ({{protocol}})"
        }
      ]
    },
    {
      "id": 2,
      "title": "Outgoing loss — $source → *",
