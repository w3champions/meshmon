{
  "openapi": "3.1.0",
  "info": {
    "title": "meshmon Service API",
    "description": "Operator-facing HTTP API for the meshmon service. Agent-facing endpoints (Protobuf) are documented separately in `crates/protocol/proto/meshmon.proto`.",
    "contact": {
      "name": "meshmon contributors"
    },
    "license": {
      "name": "AGPL-3.0-or-later",
      "identifier": "AGPL-3.0-or-later"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/agents": {
      "get": {
        "tags": [
          "agents"
        ],
        "summary": "`GET /api/agents` — return every agent known to the registry.",
        "description": "The response is a flat JSON array sorted by `id` for determinism.\nEmpty when no agents have registered yet.",
        "operationId": "list_agents",
        "responses": {
          "200": {
            "description": "List of all registered agents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentSummary"
                  }
                }
              }
            }
          },
          "401": {
            "description": "No active session"
          }
        }
      }
    },
    "/api/agents/{id}": {
      "get": {
        "tags": [
          "agents"
        ],
        "summary": "`GET /api/agents/{id}` — return a single agent by id.",
        "description": "Returns 404 with a JSON error body when the id is not found in the\ncurrent registry snapshot.",
        "operationId": "get_agent",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Agent identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentSummary"
                }
              }
            }
          },
          "401": {
            "description": "No active session"
          },
          "404": {
            "description": "Agent not found"
          }
        }
      }
    },
    "/api/alerts": {
      "get": {
        "tags": [
          "alerts"
        ],
        "summary": "`GET /api/alerts` — proxy active alerts from Alertmanager.",
        "description": "Returns a normalized `Vec<AlertSummary>`. Upstream query parameters\n(`active`, `silenced`, `inhibited`, `unprocessed`, `filter`) are\nforwarded verbatim.\n\n- **503** when `upstream.alertmanager_url` is not configured.\n- **502** when the upstream is unreachable or returns a non-2xx status.",
        "operationId": "list_alerts",
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "description": "Include active alerts.",
            "required": false,
            "schema": {
              "type": [
                "boolean",
                "null"
              ]
            }
          },
          {
            "name": "silenced",
            "in": "query",
            "description": "Include silenced alerts.",
            "required": false,
            "schema": {
              "type": [
                "boolean",
                "null"
              ]
            }
          },
          {
            "name": "inhibited",
            "in": "query",
            "description": "Include inhibited alerts.",
            "required": false,
            "schema": {
              "type": [
                "boolean",
                "null"
              ]
            }
          },
          {
            "name": "unprocessed",
            "in": "query",
            "description": "Include unprocessed alerts.",
            "required": false,
            "schema": {
              "type": [
                "boolean",
                "null"
              ]
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Single PromQL-style label matcher expression, e.g.\n`alertname=\"HighLatency\"`. Multiple matchers must be combined into\none expression by the caller (Alertmanager accepts comma-separated\nmatchers inside a single `filter` value).",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Active alerts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AlertSummary"
                  }
                }
              }
            }
          },
          "401": {
            "description": "No active session"
          },
          "502": {
            "description": "Upstream error"
          },
          "503": {
            "description": "Alertmanager not configured"
          }
        }
      }
    },
    "/api/alerts/{fingerprint}": {
      "get": {
        "tags": [
          "alerts"
        ],
        "summary": "`GET /api/alerts/{fingerprint}` — single alert by fingerprint.",
        "description": "Fetches the full alert list from Alertmanager and filters client-side\nby fingerprint (the v2 API has no single-alert endpoint).\n\n- **404** when no alert matches the fingerprint.\n- **502** when the upstream is unreachable or returns a non-2xx status.\n- **503** when `upstream.alertmanager_url` is not configured.",
        "operationId": "get_alert",
        "parameters": [
          {
            "name": "fingerprint",
            "in": "path",
            "description": "Alert fingerprint (hex)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alert detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlertSummary"
                }
              }
            }
          },
          "401": {
            "description": "No active session"
          },
          "404": {
            "description": "Alert not found"
          },
          "502": {
            "description": "Upstream error"
          },
          "503": {
            "description": "Alertmanager not configured"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "POST `/api/auth/login` — authenticate and issue a session cookie.",
        "description": "- 200 + `LoginResponse` on success\n- 401 on wrong credentials (JSON body: `{\"error\": \"invalid credentials\"}`)\n- 500 only on infra failure (session store I/O, verify-task panic)",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Logged in",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          },
          "429": {
            "description": "Too many attempts from this IP"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "POST `/api/auth/logout` — invalidate the current session.",
        "description": "Idempotent: 200 whether or not the caller was logged in. The cookie is\ncleared either way.",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "Logged out"
          }
        }
      }
    },
    "/api/metrics/query": {
      "get": {
        "tags": [
          "metrics"
        ],
        "summary": "`GET /api/metrics/query` -- proxy an instant query to VictoriaMetrics.",
        "description": "The query expression must reference at least one `meshmon_<ident>`\nmetric. Aggregators and function wrappers around meshmon metrics are\nallowed. Queries that touch no meshmon metric are rejected with 400.\n\n- **400** when the query references no `meshmon_` metric.\n- **502** when the upstream is unreachable or returns an error.\n- **503** when `upstream.vm_url` is not configured.",
        "operationId": "query_instant",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "PromQL expression (must reference a meshmon_ metric)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "time",
            "in": "query",
            "description": "Evaluation timestamp",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Instant query result (VM JSON pass-through)"
          },
          "400": {
            "description": "Query rejected by whitelist"
          },
          "401": {
            "description": "No active session"
          },
          "502": {
            "description": "Upstream error"
          },
          "503": {
            "description": "VictoriaMetrics not configured"
          }
        }
      }
    },
    "/api/metrics/query_range": {
      "get": {
        "tags": [
          "metrics"
        ],
        "summary": "`GET /api/metrics/query_range` -- proxy a range query to VictoriaMetrics.",
        "description": "The query expression must reference at least one `meshmon_<ident>`\nmetric. Aggregators and function wrappers around meshmon metrics are\nallowed. Queries that touch no meshmon metric are rejected with 400.\n\n- **400** when the query references no `meshmon_` metric.\n- **502** when the upstream is unreachable or returns an error.\n- **503** when `upstream.vm_url` is not configured.",
        "operationId": "query_range",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "PromQL expression (must reference a meshmon_ metric)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start timestamp",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End timestamp",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "step",
            "in": "query",
            "description": "Query resolution step",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Range query result (VM JSON pass-through)"
          },
          "400": {
            "description": "Query rejected by whitelist"
          },
          "401": {
            "description": "No active session"
          },
          "502": {
            "description": "Upstream error"
          },
          "503": {
            "description": "VictoriaMetrics not configured"
          }
        }
      }
    },
    "/api/paths/{src}/{tgt}/overview": {
      "get": {
        "tags": [
          "paths"
        ],
        "summary": "`GET /api/paths/{src}/{tgt}/overview` — aggregate path-detail payload.",
        "operationId": "path_overview",
        "parameters": [
          {
            "name": "src",
            "in": "path",
            "description": "Source agent id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tgt",
            "in": "path",
            "description": "Target agent id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "description": "Start of the time window (inclusive). Defaults to `to - 24h`.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "description": "End of the time window (inclusive). Defaults to now.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            }
          },
          {
            "name": "protocol",
            "in": "query",
            "description": "Optional protocol override (`icmp`, `udp`, or `tcp`). Returns 400 on\nany other value.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aggregated path detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PathOverviewResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid protocol override"
          },
          "401": {
            "description": "No active session"
          },
          "404": {
            "description": "Source or target agent not found"
          }
        }
      }
    },
    "/api/paths/{src}/{tgt}/routes": {
      "get": {
        "tags": [
          "routes"
        ],
        "summary": "`GET /api/paths/{src}/{tgt}/routes` — return a paginated, time-filtered\nlist of route snapshot summaries (without hop detail).",
        "operationId": "list_routes",
        "parameters": [
          {
            "name": "src",
            "in": "path",
            "description": "Source agent id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tgt",
            "in": "path",
            "description": "Target agent id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "description": "Start of the time window (inclusive). Defaults to 24 h ago.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "description": "End of the time window (inclusive). Defaults to now.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum rows to return (1..=500, default 100).",
            "required": false,
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int64"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Offset for pagination (>= 0, default 0).",
            "required": false,
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int64"
            }
          },
          {
            "name": "protocol",
            "in": "query",
            "description": "Protocol filter: icmp, tcp, or udp.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated route snapshots",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoutesPage"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters"
          },
          "401": {
            "description": "No active session"
          }
        }
      }
    },
    "/api/paths/{src}/{tgt}/routes/latest": {
      "get": {
        "tags": [
          "routes"
        ],
        "summary": "`GET /api/paths/{src}/{tgt}/routes/latest` — return the most recent\nroute snapshot for the given source, target, and protocol.",
        "operationId": "get_route_latest",
        "parameters": [
          {
            "name": "src",
            "in": "path",
            "description": "Source agent id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tgt",
            "in": "path",
            "description": "Target agent id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "protocol",
            "in": "query",
            "description": "Protocol filter: icmp, tcp, or udp.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "icmp"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Latest route snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RouteSnapshotDetail"
                }
              }
            }
          },
          "400": {
            "description": "Invalid protocol"
          },
          "401": {
            "description": "No active session"
          },
          "404": {
            "description": "No snapshot found"
          }
        }
      }
    },
    "/api/paths/{src}/{tgt}/routes/{snapshot_id}": {
      "get": {
        "tags": [
          "routes"
        ],
        "summary": "`GET /api/paths/{src}/{tgt}/routes/{snapshot_id}` — return a single\nroute snapshot by database id.",
        "operationId": "get_route_by_id",
        "parameters": [
          {
            "name": "src",
            "in": "path",
            "description": "Source agent id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tgt",
            "in": "path",
            "description": "Target agent id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "snapshot_id",
            "in": "path",
            "description": "Snapshot database id",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Route snapshot detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RouteSnapshotDetail"
                }
              }
            }
          },
          "401": {
            "description": "No active session"
          },
          "404": {
            "description": "Snapshot not found"
          }
        }
      }
    },
    "/api/routes/recent": {
      "get": {
        "tags": [
          "routes"
        ],
        "summary": "`GET /api/routes/recent` — returns the latest route snapshot per\n`(source_id, target_id)` pair, newest first, up to `limit` rows\n(default 10, max 100).",
        "operationId": "list_recent_routes",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum rows to return (1..=100, default 10).",
            "required": false,
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent route snapshots across all pairs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RouteSnapshotSummary"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid limit"
          },
          "401": {
            "description": "No active session"
          }
        }
      }
    },
    "/api/session": {
      "get": {
        "tags": [
          "session"
        ],
        "summary": "`GET /api/session` — return the session probe body.",
        "description": "Wired behind the `login_required!` layer in [`crate::http::router`],\nso unauthenticated requests are short-circuited with a bare 401\nbefore reaching this handler. The 401 response is documented here\nso the generated OpenAPI schema tells SPA clients exactly what to\nexpect.",
        "operationId": "session",
        "responses": {
          "200": {
            "description": "Active session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "401": {
            "description": "No active session"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AgentSummary": {
        "type": "object",
        "description": "Summary of a single agent, returned by the list and detail endpoints.\n\nWrite-only on the server (constructed and serialized, never parsed) so\nonly `Serialize` is derived.",
        "required": [
          "id",
          "display_name",
          "ip",
          "registered_at",
          "last_seen_at"
        ],
        "properties": {
          "agent_version": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional agent version string."
          },
          "display_name": {
            "type": "string",
            "description": "Human-readable display label."
          },
          "id": {
            "type": "string",
            "description": "Unique agent identifier (matches the agent's `AGENT_ID` env var)."
          },
          "ip": {
            "type": "string",
            "description": "Agent source IP (host address only, CIDR prefix stripped)."
          },
          "last_seen_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last successful push (register/metrics/snapshot)."
          },
          "lat": {
            "type": [
              "number",
              "null"
            ],
            "format": "double",
            "description": "Optional latitude."
          },
          "location": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional free-form location string."
          },
          "lon": {
            "type": [
              "number",
              "null"
            ],
            "format": "double",
            "description": "Optional longitude."
          },
          "registered_at": {
            "type": "string",
            "format": "date-time",
            "description": "When this agent first registered."
          }
        }
      },
      "AlertSummary": {
        "type": "object",
        "description": "Normalized alert summary exposed by the meshmon API.\n\nDerived from the Alertmanager v2 alert model, keeping only the fields\nthe frontend needs. `generatorURL` and other upstream-only fields are\nintentionally dropped.",
        "required": [
          "fingerprint",
          "labels",
          "state",
          "starts_at",
          "ends_at"
        ],
        "properties": {
          "description": {
            "type": [
              "string",
              "null"
            ],
            "description": "Longer description from the `description` annotation."
          },
          "ends_at": {
            "type": "string",
            "description": "RFC 3339 timestamp when the alert resolved (may be empty/zero for\nactive alerts)."
          },
          "fingerprint": {
            "type": "string",
            "description": "Alertmanager fingerprint (hex string), unique per alert group."
          },
          "labels": {
            "type": "object",
            "description": "Label set attached to the alert (alertname, severity, etc.).",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "starts_at": {
            "type": "string",
            "description": "RFC 3339 timestamp when the alert started firing."
          },
          "state": {
            "type": "string",
            "description": "Alert state: `active`, `suppressed`, or `unprocessed`."
          },
          "summary": {
            "type": [
              "string",
              "null"
            ],
            "description": "Short human-readable summary from the `summary` annotation."
          }
        }
      },
      "HopIpJson": {
        "type": "object",
        "description": "JSON representation of an observed IP at a hop.",
        "required": [
          "ip",
          "freq"
        ],
        "properties": {
          "freq": {
            "type": "number",
            "format": "double",
            "description": "Fraction of probes that observed this IP at this hop."
          },
          "ip": {
            "type": "string",
            "description": "Human-readable IP string (IPv4 or IPv6 `to_string()` form)."
          }
        }
      },
      "HopJson": {
        "type": "object",
        "description": "JSON representation of a single traceroute hop as stored in\n`route_snapshots.hops`.",
        "required": [
          "position",
          "observed_ips",
          "avg_rtt_micros",
          "stddev_rtt_micros",
          "loss_pct"
        ],
        "properties": {
          "avg_rtt_micros": {
            "type": "integer",
            "format": "int32",
            "description": "Mean RTT to this hop, in microseconds.",
            "minimum": 0
          },
          "loss_pct": {
            "type": "number",
            "format": "double",
            "description": "Fraction of probes with no response at this hop."
          },
          "observed_ips": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HopIpJson"
            },
            "description": "IP addresses observed at this hop and their frequencies."
          },
          "position": {
            "type": "integer",
            "format": "int32",
            "description": "1-indexed TTL / hop position (matches the protocol contract).",
            "minimum": 0
          },
          "stddev_rtt_micros": {
            "type": "integer",
            "format": "int32",
            "description": "Standard deviation of RTT to this hop, in microseconds.",
            "minimum": 0
          }
        }
      },
      "InstantQuery": {
        "type": "object",
        "description": "Query parameters for `GET /api/metrics/query` (instant query).",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "PromQL expression. Must reference at least one `meshmon_` metric."
          },
          "time": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional evaluation timestamp (RFC 3339 or Unix epoch)."
          }
        }
      },
      "LatestByProtocol": {
        "type": "object",
        "description": "Per-protocol latest-snapshot map. Each field is independent so the UI can\nrender \"icmp present, udp/tcp empty\" without a sentinel value.",
        "properties": {
          "icmp": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/RouteSnapshotDetail",
                "description": "Latest ICMP snapshot in window, if any."
              }
            ]
          },
          "tcp": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/RouteSnapshotDetail",
                "description": "Latest TCP snapshot in window, if any."
              }
            ]
          },
          "udp": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/RouteSnapshotDetail",
                "description": "Latest UDP snapshot in window, if any."
              }
            ]
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "description": "POST body for `/api/auth/login`.",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "password": {
            "type": "string",
            "description": "Plaintext password. Verified against the PHC hash via argon2 inside\n`spawn_blocking`."
          },
          "username": {
            "type": "string",
            "description": "Username from the configured `[auth.users]` list."
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "description": "JSON response body for `/api/auth/login`.",
        "required": [
          "username"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "Echoed username on success."
          }
        }
      },
      "PathMetrics": {
        "type": "object",
        "description": "VictoriaMetrics-sourced RTT / loss series for the primary protocol.",
        "required": [
          "rtt_series",
          "loss_series"
        ],
        "properties": {
          "loss_current": {
            "type": [
              "number",
              "null"
            ],
            "format": "double",
            "description": "Last loss value (fraction), or null if the series is empty."
          },
          "loss_series": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "number",
                "format": "double"
              }
            },
            "description": "`[epoch_ms, loss_fraction]` tuples. Fractional — `0.05` = 5%."
          },
          "rtt_current": {
            "type": [
              "number",
              "null"
            ],
            "format": "double",
            "description": "Last RTT value (ms), or null if the series is empty."
          },
          "rtt_series": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "number",
                "format": "double"
              }
            },
            "description": "`[epoch_ms, rtt_ms]` tuples."
          }
        }
      },
      "PathOverviewResponse": {
        "type": "object",
        "description": "Aggregated response for the Path Detail page.",
        "required": [
          "source",
          "target",
          "latest_by_protocol",
          "recent_snapshots",
          "recent_snapshots_truncated",
          "window",
          "step"
        ],
        "properties": {
          "latest_by_protocol": {
            "$ref": "#/components/schemas/LatestByProtocol",
            "description": "Latest snapshot per protocol within the window (each field optional)."
          },
          "metrics": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PathMetrics",
                "description": "VM series for the primary protocol, or `null` when the VM was\nunreachable or misconfigured."
              }
            ]
          },
          "primary_protocol": {
            "type": [
              "string",
              "null"
            ],
            "description": "Server-picked primary protocol (`icmp`, `udp`, or `tcp`). `null`\nonly when no protocol has any snapshot in the window; callers should\ntreat that as \"show a neutral empty state\"."
          },
          "recent_snapshots": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RouteSnapshotSummary"
            },
            "description": "Recent snapshots in the window in descending `observed_at` order,\nfiltered to the resolved [`PathOverviewResponse::primary_protocol`].\nCapped at [`RECENT_LIMIT`]; no hop detail. Empty when no primary\nprotocol could be resolved (no data for any protocol in the\nwindow)."
          },
          "recent_snapshots_truncated": {
            "type": "boolean",
            "description": "`true` when the per-primary-protocol `recent_snapshots` list was\nclamped at [`RECENT_LIMIT`]. Since the list is protocol-scoped\nfrom the start, this flag is always honest for the operator-visible\nbanner (\"narrow the window for more\")."
          },
          "source": {
            "$ref": "#/components/schemas/AgentSummary",
            "description": "Source agent metadata."
          },
          "step": {
            "type": "string",
            "description": "Server-chosen Prometheus step (`1m`, `5m`, `1h`, `6h`)."
          },
          "target": {
            "$ref": "#/components/schemas/AgentSummary",
            "description": "Target agent metadata."
          },
          "window": {
            "$ref": "#/components/schemas/WindowBounds",
            "description": "Echoed resolved window bounds (inclusive)."
          }
        }
      },
      "PathSummaryJson": {
        "type": "object",
        "description": "JSON representation of the aggregated path summary stored in\n`route_snapshots.path_summary`.",
        "required": [
          "avg_rtt_micros",
          "loss_pct",
          "hop_count"
        ],
        "properties": {
          "avg_rtt_micros": {
            "type": "integer",
            "format": "int32",
            "description": "Mean RTT across all hops, in microseconds.",
            "minimum": 0
          },
          "hop_count": {
            "type": "integer",
            "format": "int32",
            "description": "Total number of hops in the route.",
            "minimum": 0
          },
          "loss_pct": {
            "type": "number",
            "format": "double",
            "description": "Overall path loss fraction."
          }
        }
      },
      "RangeQuery": {
        "type": "object",
        "description": "Query parameters for `GET /api/metrics/query_range` (range query).",
        "required": [
          "query",
          "start",
          "end",
          "step"
        ],
        "properties": {
          "end": {
            "type": "string",
            "description": "End timestamp (RFC 3339 or Unix epoch)."
          },
          "query": {
            "type": "string",
            "description": "PromQL expression. Must reference at least one `meshmon_` metric."
          },
          "start": {
            "type": "string",
            "description": "Start timestamp (RFC 3339 or Unix epoch)."
          },
          "step": {
            "type": "string",
            "description": "Query resolution step (e.g. `15s`, `1m`)."
          }
        }
      },
      "RouteSnapshotDetail": {
        "type": "object",
        "description": "Full detail of a single route snapshot (includes hops).",
        "required": [
          "id",
          "source_id",
          "target_id",
          "protocol",
          "observed_at",
          "hops"
        ],
        "properties": {
          "hops": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HopJson"
            },
            "description": "Hop-by-hop detail."
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Database row id."
          },
          "observed_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the snapshot was observed."
          },
          "path_summary": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PathSummaryJson",
                "description": "Aggregated path summary (optional)."
              }
            ]
          },
          "protocol": {
            "type": "string",
            "description": "Protocol used for the traceroute (icmp, tcp, udp)."
          },
          "source_id": {
            "type": "string",
            "description": "Source agent identifier."
          },
          "target_id": {
            "type": "string",
            "description": "Target agent identifier."
          }
        }
      },
      "RouteSnapshotSummary": {
        "type": "object",
        "description": "Summary of a route snapshot (no hops — used in list responses).",
        "required": [
          "id",
          "source_id",
          "target_id",
          "protocol",
          "observed_at"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Database row id."
          },
          "observed_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the snapshot was observed."
          },
          "path_summary": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PathSummaryJson",
                "description": "Aggregated path summary (optional)."
              }
            ]
          },
          "protocol": {
            "type": "string",
            "description": "Protocol used for the traceroute (icmp, tcp, udp)."
          },
          "source_id": {
            "type": "string",
            "description": "Source agent identifier."
          },
          "target_id": {
            "type": "string",
            "description": "Target agent identifier."
          }
        }
      },
      "RoutesPage": {
        "type": "object",
        "description": "Paginated response of route snapshot summaries.",
        "required": [
          "items",
          "offset",
          "limit"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RouteSnapshotSummary"
            },
            "description": "Snapshot summaries in descending `observed_at` order."
          },
          "limit": {
            "type": "integer",
            "format": "int64",
            "description": "Applied limit."
          },
          "offset": {
            "type": "integer",
            "format": "int64",
            "description": "Current offset."
          }
        }
      },
      "SessionResponse": {
        "type": "object",
        "description": "Minimal session probe response.\n\nWrite-only on the server — we only ever construct and serialize this\ntype, never parse one back in — so only `Serialize` is derived.",
        "required": [
          "version",
          "username"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "Signed-in username. The SPA hydrates its auth store from this\nso a hard-refresh tab still knows who's signed in."
          },
          "version": {
            "type": "string",
            "description": "`CARGO_PKG_VERSION` of the running service — surfaced so the SPA\ncan warn when the user's loaded bundle is older than the server."
          }
        }
      },
      "WindowBounds": {
        "type": "object",
        "description": "Inclusive time window bounds echoed back to the caller.",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string",
            "format": "date-time",
            "description": "Start of the window (inclusive)."
          },
          "to": {
            "type": "string",
            "format": "date-time",
            "description": "End of the window (inclusive)."
          }
        }
      }
    }
  }
}
