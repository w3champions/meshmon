{
  "name": "meshmon-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "openapi:types": "openapi-typescript src/api/openapi.gen.json -o src/api/schema.gen.ts",
    "dev": "npm run openapi:types && vite",
    "build": "npm run openapi:types && biome check ./src && tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "npm run openapi:types && tsc --noEmit",
    "lint": "npm run openapi:types && biome check ./src",
    "lint:fix": "npm run openapi:types && biome check --write ./src",
    "format": "biome format --write ./src",
    "test": "npm run openapi:types && vitest run",
    "test:watch": "npm run openapi:types && vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.90.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.400.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.66.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query-devtools": "^5.90.0",
    "@tanstack/router-devtools": "^1.90.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.11.30",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.4"
  }
}
