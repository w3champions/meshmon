{
  "name": "meshmon-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "openapi:types": "openapi-typescript src/api/openapi.gen.json -o src/api/schema.gen.ts",
    "dev": "npm run openapi:types && vite",
    "build": "npm run openapi:types && biome check ./src && tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "npm run openapi:types && tsc --noEmit",
    "lint": "npm run openapi:types && biome check ./src",
    "lint:fix": "npm run openapi:types && biome check --write ./src",
    "format": "biome format --write ./src",
    "test": "npm run openapi:types && vitest run",
    "test:watch": "npm run openapi:types && vitest"
  },
  "dependencies": {
    "@geoman-io/leaflet-geoman-free": "^2.19.3",
    "@hookform/resolvers": "^5.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.90.0",
    "@tanstack/react-table": "^8.21.3",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/circle": "^7.3.5",
    "@types/leaflet.markercluster": "^1.5.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.2",
    "cytoscape-dagre": "^2.5.0",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.400.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.66.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query-devtools": "^5.90.0",
    "@tanstack/router-devtools": "^1.90.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cytoscape": "^3.31.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.11.30",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.4"
  }
}
