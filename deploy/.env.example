# deploy/.env.example — copy to deploy/.env and fill in each value.
#
# .env is gitignored (see root .gitignore — `deploy/.env` is explicit).
# NEVER commit a filled .env.
#
# docker compose auto-loads .env from the directory the compose file
# lives in; no --env-file flag needed.
#
# Compose interpolates $VAR / ${VAR} in .env values. Escape every
# literal '$' as '$$' — Argon2 PHC strings contain '$' separators, so
# an unescaped hash becomes a blank string after interpolation. The
# hashes below are pre-escaped; keep the '$$' when replacing CHANGEME.

# ===========================================================================
# Authentication (required)
# ===========================================================================
# Argon2 PHC hash of the admin password. Generate offline and then
# double every '$' before pasting:
#
#   RAW=$(echo -n 'your-password' | argon2 "$(openssl rand -base64 16)" -id -t 2 -m 19 -p 1 -e)
#   echo "$RAW" | sed 's/\$/$$/g'
#
# The plaintext password is never stored. For multi-user setups, add
# more [[auth.users]] entries in meshmon.toml with your own env-var
# names (e.g. MESHMON_ALICE_PASSWORD_HASH).
MESHMON_ADMIN_PASSWORD_HASH=$$argon2id$$v=19$$m=524288,t=2,p=1$$CHANGEME$$CHANGEME

# Shared bearer token every agent presents on gRPC calls. Generate with:
#
#   openssl rand -hex 32
MESHMON_AGENT_TOKEN=CHANGEME_64_HEX_CHARS

# ===========================================================================
# Postgres (required)
# ===========================================================================
# Full read/write role used by the service for migrations + ingestion.
MESHMON_PG_PASSWORD=CHANGEME

# Read-only role used by bundled Grafana's MeshmonPostgres datasource.
# The service flips the role from NOLOGIN to LOGIN with this password on
# boot — see crates/service/src/db.rs::apply_grafana_role_password.
MESHMON_PG_GRAFANA_PASSWORD=CHANGEME

# ===========================================================================
# Alertmanager public URL (optional)
# ===========================================================================
# When set, AM runs with --web.external-url=<MESHMON_PUBLIC_URL>/alertmanager
# so Discord notifications carry clean absolute links back to the AM UI.
# Leave unset for localhost-only setups (fallback: http://localhost:8080).
#
# MESHMON_PUBLIC_URL=https://meshmon.example.com

# ===========================================================================
# Discord webhooks (optional — recommended for alert delivery)
# ===========================================================================
# Delivered to Alertmanager via docker-compose's native `secrets:` stanza
# with `environment:` source. NOT written to the host filesystem.
#
# Leave unset (or empty) and AM will log a delivery error on every fire
# — loud failure mode. Set at least the default webhook for real
# notifications.
#
# MESHMON_DISCORD_WEBHOOK=https://discord.com/api/webhooks/<id>/<token>
# MESHMON_DISCORD_WEBHOOK_CRITICAL=https://discord.com/api/webhooks/<id>/<token>
# MESHMON_DISCORD_WEBHOOK_INFO=https://discord.com/api/webhooks/<id>/<token>

# ===========================================================================
# /metrics basic auth (optional)
# ===========================================================================
# Only relevant when [service.metrics_auth] is populated in meshmon.toml.
# Leave unset to keep /metrics unauthenticated (fine for bridge-only scrape).
#
# MESHMON_METRICS_PASSWORD_HASH=$$argon2id$$v=19$$m=524288,t=2,p=1$$CHANGEME$$CHANGEME
