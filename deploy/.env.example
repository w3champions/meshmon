# Shared bearer token for agent -> service authentication.
# Generate with: openssl rand -hex 32
MESHMON_AGENT_TOKEN=replace-me

# Postgres password for the Timescale container (T03, T24).
MESHMON_PG_PASSWORD=replace-me

# Argon2 hash of the admin password (T05).
# Produce with: echo -n "yourpassword" | argon2 "$(openssl rand -hex 16)" -e
MESHMON_ADMIN_PASSWORD_HASH=replace-me

# Optional Discord webhook for Alertmanager routing (T22).
# Leave blank to disable notifications.
MESHMON_DISCORD_WEBHOOK=

# Image tag to deploy. Leave at "latest" or pin to "main-<sha>".
TAG=latest
