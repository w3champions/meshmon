# deploy/versions.env — single source of truth for image tags used across the
# meshmon alert pipeline.
#
# Consumers of this file:
#   1. scripts/validate-alerts.sh      — sources this file to pull VM_TAG,
#                                        VMALERT_TAG, and VMALERT_TOOL_TAG for
#                                        dry-run validation and unit-test runs.
#   2. scripts/smoke-alerts.sh         — sources this file to start the smoke
#                                        harness containers (VM_TAG, VMALERT_TAG,
#                                        ALERTMANAGER_TAG).
#   3. deploy/alerts/test-harness/     — docker-compose.yml in the test harness
#                                        uses these tags via env_file or
#                                        inline shell expansion.
#   4. .github/workflows/ci.yml        — sources this file so CI pins exactly
#                                        the same images that were tested locally.
#   5. Ad-hoc docker commands          — operators can source this file before
#                                        running one-off docker run invocations:
#                                        source deploy/versions.env &&
#                                        docker run victoriametrics/vmalert:$VMALERT_TAG ...
#
# Updating tags:
#   Bump the relevant variable here, run the full validation + smoke suite, then
#   commit the change. All consumers will pick up the new tag automatically.
# ---------------------------------------------------------------------------

# VictoriaMetrics TSDB (used in smoke harness and test-harness docker-compose).
VM_TAG=v1.140.0

# vmalert — provides the -dryRun -rule= syntax check AND drives alerting in the
# smoke harness and production docker-compose stack.
# Image: victoriametrics/vmalert:<VMALERT_TAG>
VMALERT_TAG=v1.140.0

# vmalert-tool — provides the `unittest` subcommand used for unit-testing alert
# rule files (vmalert-tool unittest --config ...).
# NOTE: This is a DIFFERENT image from vmalert even though both share the same
# version tag. The image is victoriametrics/vmalert-tool:<VMALERT_TOOL_TAG>.
# Do NOT confuse this with vmalert (victoriametrics/vmalert) — that image does
# NOT provide the unittest subcommand.
VMALERT_TOOL_TAG=v1.140.0

# Alertmanager — provides amtool at /bin/amtool and runs the alert routing
# pipeline in the smoke harness and production stack.
# Image: prom/alertmanager:<ALERTMANAGER_TAG>
ALERTMANAGER_TAG=v0.32.0

# Grafana OSS image used by the dashboard smoke harness and (in T24) by the
# bundled deployment compose.
# Image: grafana/grafana-oss:<GRAFANA_TAG>
GRAFANA_TAG=13.0.1
