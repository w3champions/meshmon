# deploy/versions.env — tags consumed by test helpers that spin up VM /
# vmalert / vmalert-tool / Alertmanager / Grafana out-of-band (i.e. not
# through deploy/docker-compose.yml, which pins its own images literally).
#
# Consumers of this file:
#   1. crates/service/tests/alerts_validation.rs — loads the file at test
#      start to pull VMALERT_TAG, VMALERT_TOOL_TAG, and ALERTMANAGER_TAG
#      for `docker run --rm` syntax-check invocations.
#   2. Ad-hoc docker commands. Example:
#      source deploy/versions.env &&
#        docker run --rm victoriametrics/vmalert:$VMALERT_TAG --help
#
# `deploy/docker-compose.yml` does NOT source this file — bump the tags
# there independently. Keep the two in sync manually.
# ---------------------------------------------------------------------------

# VictoriaMetrics TSDB. Ad-hoc only — not consumed by alerts_validation.rs.
VM_TAG=v1.140.0

# vmalert — `-dryRun -rule=` syntax check.
# Image: victoriametrics/vmalert:<VMALERT_TAG>
VMALERT_TAG=v1.140.0

# vmalert-tool — the `unittest` subcommand.
# NOTE: This is a DIFFERENT image from vmalert even though both share the same
# version tag. The image is victoriametrics/vmalert-tool:<VMALERT_TOOL_TAG>.
# Do NOT confuse this with vmalert (victoriametrics/vmalert) — that image does
# NOT provide the unittest subcommand.
VMALERT_TOOL_TAG=v1.140.0

# Alertmanager — `amtool check-config`.
# Image: prom/alertmanager:<ALERTMANAGER_TAG>
ALERTMANAGER_TAG=v0.32.0

# Grafana OSS base image. Ad-hoc only — docker-compose.yml's
# meshmon-grafana build stanza pins this independently.
# Image: grafana/grafana-oss:<GRAFANA_TAG>
GRAFANA_TAG=13.0.1
