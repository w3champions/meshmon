# Per-host agent configuration. Copy to agent.env and fill in, then:
#
#   docker compose -f docker-compose.agent.yml --env-file agent.env up -d
#
# This file is an example and safe to commit; agent.env itself is
# per-host state and should stay local.

# Where the central meshmon service is reachable. HTTPS strongly
# recommended in production — see docs/deployment.md § Enabling TLS.
MESHMON_SERVICE_URL=https://meshmon.example.com

# Shared bearer token. MUST match MESHMON_AGENT_TOKEN in the central
# service's deploy/.env.
MESHMON_AGENT_TOKEN=

# Per-host identity. AGENT_ID must be unique across the fleet and
# stable across restarts (it's the key the service registers against).
AGENT_ID=my-node-1
AGENT_DISPLAY_NAME=My Node 1
AGENT_LOCATION=City, Country

# Externally-reachable IP (v4 or v6). Peers use this to direct their
# probes at this agent, so it must be routable from every other agent.
AGENT_IP=1.2.3.4

# Coordinates for the fleet-overview map. Decimal degrees; latitude in
# [-90, 90], longitude in [-180, 180].
AGENT_LAT=40.7128
AGENT_LON=-74.0060

# Probe echo listener ports. Defaults match the service's built-in
# defaults; uncomment only to override.
# MESHMON_TCP_PROBE_PORT=8002
# MESHMON_UDP_PROBE_PORT=8005

# Cap on concurrent ICMP/trippy rounds. Lower if raw-socket/thread use
# is too high on constrained hosts.
# MESHMON_ICMP_TARGET_CONCURRENCY=32

# Tracing output format. `json` is the production default; set
# `compact` for human-readable dev output. Mirrors the service's
# `[logging] format` values.
# MESHMON_AGENT_LOG_FORMAT=json

# Tracing filter. `meshmon_agent=debug` is useful when bootstrapping a
# new agent.
# RUST_LOG=meshmon_agent=info,warn
